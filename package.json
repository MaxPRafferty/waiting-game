{
  "name": "waiting-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"yellow,cyan\" \"tsx watch src/index.ts\" \"vite\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "vite",
    "dev:all": "concurrently -n \"REDIS,SERVER,CLIENT\" -c \"magenta,yellow,cyan\" \"npm run redis:start\" \"npm run dev:server\" \"npm run dev:client\"",
    "redis:start": "redis-server",
    "redis:stop": "redis-cli shutdown",
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "build:dry": "tsc --noEmit",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/express": "^5.0.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "satori": "^0.26.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "redis-cli": "^2.1.2",
    "redis-server": "^1.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
